{"content":[{"id":"26253af7","settings":[],"elements":[{"id":"635606f2","settings":{"title":"Add Your Heading Text Here","editor":"<div class=\"container\"><div id=\"model-response-message-contentr_d40b2f84f9f40742\" class=\"markdown markdown-main-panel enable-updated-hr-color\" dir=\"ltr\" aria-live=\"polite\" aria-busy=\"false\"><p data-path-to-node=\"1\"><strong>Product Description <\/strong><\/p><p data-path-to-node=\"1\">Step into elegance with this beautifully crafted saree set. The fabric boasts a graceful drape and premium texture for maximum comfort during long events. Complete with a matching blouse piece, this outfit is designed to make a statement at casual gatherings and festive occasions.<\/p><p data-path-to-node=\"2\"><strong>Saree<\/strong><\/p><p data-path-to-node=\"5,0,0\">Fabric: Woven from premium quality, breathable soft linen cotton fabric.<\/p><p data-path-to-node=\"5,1,0\">Design &amp; Pattern: Features an elegant all-over print layout paired with traditional patterns on the body and border.<\/p><p data-path-to-node=\"5,2,0\">Length: Traditional saree length measures 5.50 meters.<\/p><p data-path-to-node=\"5,3,0\">Details: Enhanced beautifully with decorative, fancy cotton tassels along the pallu edge.<\/p><p data-path-to-node=\"4\"><strong>Blouse<\/strong><\/p><p data-path-to-node=\"3,0,0\">Fabric: Made from matching premium soft linen cotton fabric.<\/p><p data-path-to-node=\"3,1,0\">Length: Unstitched blouse piece measures 0.80 meters, allowing for custom boutique tailoring.<\/p><p data-path-to-node=\"3,2,0\">Style: Designed to perfectly complement the printed aesthetic of the saree as seen in photos<\/p><p data-path-to-node=\"8\"><strong>Wash Instructions <\/strong><\/p><p data-path-to-node=\"8\">First Wash: Dry clean recommended to maintain the fabric texture and sequence work.<\/p><p data-path-to-node=\"9\">Subsequent Washes: Gentle hand wash separately in cold water using a mild liquid detergent.<\/p><p data-path-to-node=\"10\">Care Advice: Do not wring or twist. Dry in shade away from direct sunlight to prevent color fading. Iron on low heat on the reverse side only.<\/p><\/div><\/div>"},"elements":[],"isInner":false,"widgetType":"bzotech-heading-global","elType":"widget"}],"isInner":false,"elType":"container"}],"settings":{"template":"default"},"metadata":{"total_sales":"0","redux-metabox-section":"0_box_redux-bzotech_theme_option-metabox-block_product_settings","bzotech_header_page":"","bzotech_footer_page":"","bzotech_sidebar_position":"","bzotech_select_sidebar":"","bzotech_sidebar_style":"","before_append":"","after_append":"","show_title_page":"1","post_single_page_share":"","body_bg":"a:3:{s:5:\"color\";s:0:\"\";s:5:\"alpha\";s:1:\"1\";s:4:\"rgba\";s:0:\"\";}","main_color":"a:3:{s:5:\"color\";s:0:\"\";s:5:\"alpha\";s:1:\"1\";s:4:\"rgba\";s:0:\"\";}","main_color2":"a:3:{s:5:\"color\";s:0:\"\";s:5:\"alpha\";s:1:\"1\";s:4:\"rgba\";s:0:\"\";}","bzotech_page_style":"","container_width":"","add_class_body_page":"","sv_style_woo_single":"","trending_product":"0","bzotech_product_sticky_addcart":"","product_image_zoom":"","bzotech_video_product":"","show_single_itemres":"","before_append_tab":"","after_append_tab":"","product_tab_detail":"","post_views":"686","append_content_summary":"","body_typo":"a:10:{s:11:\"font-family\";s:0:\"\";s:12:\"font-options\";s:0:\"\";s:6:\"google\";s:1:\"1\";s:11:\"font-weight\";s:0:\"\";s:10:\"font-style\";s:0:\"\";s:7:\"subsets\";s:0:\"\";s:10:\"text-align\";s:0:\"\";s:9:\"font-size\";s:0:\"\";s:11:\"line-height\";s:0:\"\";s:5:\"color\";s:0:\"\";}","title_typo":"a:6:{s:11:\"font-family\";s:0:\"\";s:12:\"font-options\";s:0:\"\";s:6:\"google\";s:1:\"1\";s:11:\"font-weight\";s:0:\"\";s:10:\"font-style\";s:0:\"\";s:5:\"color\";s:0:\"\";}","bzotech_product_attribute_data":"a:1:{i:0;a:4:{s:5:\"title\";s:1:\" \";s:9:\"color_att\";a:3:{s:5:\"color\";s:0:\"\";s:5:\"alpha\";s:1:\"1\";s:4:\"rgba\";s:0:\"\";}s:9:\"image_att\";a:5:{s:3:\"url\";s:0:\"\";s:2:\"id\";s:0:\"\";s:6